{
    "IP": {
        "description": "OpenClaw 服务器地址",
        "type": "string",
        "hint": "默认 localhost 或服务器 IP",
        "default": "localhost"
    },
    "PORT": {
        "description": "OpenClaw HTTP API 端口",
        "type": "string",
        "hint": "默认 18789",
        "default": "18789"
    },
    "ADAPTER_TYPE": {
        "description": "适配器类型: responses 或 chat_completions",
        "type": "string",
        "hint": "responses: 使用 /v1/responses 端点, chat_completions: 使用 /v1/chat/completions 端点",
        "default": "responses"
    },
    "OPENCLAW_TOKEN": {
        "description": "OpenClaw 认证 Token",
        "type": "string",
        "hint": "从 OpenClaw Gateway 配置中获取",
        "default": "your_openclaw_token"
    },
    "AGENT_ID": {
        "description": "Agent ID",
        "type": "string",
        "hint": "默认 main",
        "default": "main"
    }
}